{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/assets/(.*)", "dest": "/dist/client/assets/$1" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico))", "dest": "/dist/client/$1" },
    { "src": "/favicon.png", "dest": "/dist/client/favicon.png" },
    { "src": "/(.*)", "dest": "/api/index" }
  ]
}